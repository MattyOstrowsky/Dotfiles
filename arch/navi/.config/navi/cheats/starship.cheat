#   [time]
#   disabled = false
#   time_format = "%H:%M"
#   style = "white dimmed"

# Complete list of modules
#   os, directory, git_branch, git_commit, git_state, git_status,
#   package, nodejs, python, rust, golang, java, docker_context,
#   kubernetes, terraform, env_var, cmd_duration, line_break,
#   time, fill, hostname, nix_shell, conda, memory_usage, battery,
#   shell, character, custom, status

$ query: echo ""
