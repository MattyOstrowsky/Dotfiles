{
  "$schema": "https://opencode.ai/config.json",

  "theme": "catppuccin",
  "shell": "/usr/bin/fish",

  "model": "opencode-go/deepseek-v4-pro",
  "small_model": "opencode-go/deepseek-v4-flash",

  "autoupdate": true,
  "share": "manual",

  "instructions": [
    "~/.config/opencode/AGENTS.md"
  ],

  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  },

  "lsp": true,

  "formatter": true,

  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true }
  },

  "mcp": {
    "github": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },

    "context7": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "-y", "@upstash/context7-mcp"]
    },

    "playwright": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "-y", "@playwright/mcp"]
    }

  }
}
