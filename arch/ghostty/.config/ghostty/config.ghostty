# =============================================================================
# Ghostty Configuration
# See: https://ghostty.org/docs/configuration
# =============================================================================

# --- Font --------------------------------------------------------------------
font-family = JetBrains Mono
font-size = 12
font-feature = calt
font-feature = liga

# --- Theme / Colors ----------------------------------------------------------
theme = "Catppuccin Mocha"

# --- Window ------------------------------------------------------------------
background-opacity = 0.95
background-blur-radius = 40
window-padding-x = 8
window-padding-y = 4
window-decoration = auto
window-save-state = always
resize-overlay = always

# --- Cursor ------------------------------------------------------------------
cursor-style = bar
cursor-style-blink = true

# --- Scrollback --------------------------------------------------------------
scrollback-limit = 10000

# --- Mouse -------------------------------------------------------------------
mouse-hide-while-typing = true
copy-on-select = clipboard

# --- Shell -------------------------------------------------------------------
command = /usr/bin/fish
shell-integration = fish

# --- Terminal ----------------------------------------------------------------
term = xterm-256color
confirm-close-surface = false
grapheme-width-method = unicode

# --- Notifications -----------------------------------------------------------
notify-on-command-finish = unfocused
notify-on-command-finish-after = 10s

# --- Splits ------------------------------------------------------------------
split-divider-color = 5c6370
unfocused-split-opacity = 0.75

# =============================================================================
# Keybindings (non-conflicting with Hyprland WM)
# =============================================================================

# --- Quick Terminal (global hotkey overlay) ----------------------------------
keybind = alt+shift+space=toggle_quick_terminal

# --- Split Creation (super+ctrl + vim-keys) ----------------------------------
keybind = super+ctrl+h=new_split:left
keybind = super+ctrl+j=new_split:down
keybind = super+ctrl+k=new_split:up
keybind = super+ctrl+l=new_split:right

# --- Split Navigation (super+ctrl + arrows) ----------------------------------
keybind = super+ctrl+left=goto_split:left
keybind = super+ctrl+right=goto_split:right
keybind = super+ctrl+up=goto_split:up
keybind = super+ctrl+down=goto_split:down

# --- Equalize splits ---------------------------------------------------------
keybind = super+ctrl+e=equalize_splits

# --- Close surface -----------------------------------------------------------
keybind = super+ctrl+q=close_surface
