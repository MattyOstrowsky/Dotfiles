# =============================================================================
# Ghostty Configuration
# See: https://ghostty.org/docs/configuration
# =============================================================================

# --- Font --------------------------------------------------------------------
font-family = JetBrains Mono
font-size = 12
font-feature = calt
font-feature = liga

# --- Theme / Colors ----------------------------------------------------------
theme = "Atom One Dark"

# --- Window ------------------------------------------------------------------
background-opacity = 0.95
background-blur-radius = 40
window-padding-x = 8
window-padding-y = 4
window-decoration = auto
window-save-state = always
resize-overlay = always

# --- Cursor ------------------------------------------------------------------
cursor-style = bar
cursor-style-blink = true

# --- Scrollback --------------------------------------------------------------
scrollback-limit = 10000

# --- Mouse -------------------------------------------------------------------
mouse-hide-while-typing = true
copy-on-select = clipboard

# --- Shell -------------------------------------------------------------------
command = /usr/bin/fish
shell-integration = fish

# --- Terminal ----------------------------------------------------------------
term = xterm-256color
confirm-close-surface = false
grapheme-width-method = unicode

# --- Notifications -----------------------------------------------------------
notify-on-command-finish = unfocused
notify-on-command-finish-after = 10s

# --- Splits ------------------------------------------------------------------
split-divider-color = 4C566A
unfocused-split-opacity = 0.75

# =============================================================================
# Keybindings
# =============================================================================

# --- Quick Terminal (global hotkey overlay) ----------------------------------
keybind = alt+shift+space=toggle_quick_terminal

# --- Split Creation (super + vim-keys) ---------------------------------------
keybind = super+shift+h=new_split:left
keybind = super+shift+j=new_split:down
keybind = super+shift+k=new_split:up
keybind = super+shift+l=new_split:right

# --- Split Navigation (super + arrows) ---------------------------------------
keybind = super+shift+left=goto_split:left
keybind = super+shift+right=goto_split:right
keybind = super+shift+up=goto_split:top
keybind = super+shift+down=goto_split:bottom

# --- Close surface -----------------------------------------------------------
keybind = alt+q=close_surface
